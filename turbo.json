{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "MONGODB_URI",
        "AUTH_SECRET",
        "AUTH_URL",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "ADMIN_NEXTAUTH_URL",
        "ADMIN_URL",
        "STORE_URL",
        "EMAIL_FROM",
        "SMTP_FROM",
        "SALES_EMAIL",
        "RESEND_API_KEY",
        "MEILISEARCH_HOST",
        "MEILISEARCH_ADMIN_KEY",
        "MEILISEARCH_API_KEY",
        "MEILISEARCH_MASTER_KEY",
        "ODOO_URL",
        "ODOO_DB",
        "ODOO_USERNAME",
        "ODOO_PASSWORD",
        "PAYSTACK_SECRET_KEY",
        "PAYSTACK_PUBLIC_KEY",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_STORE_URL",
        "NEXT_PUBLIC_MEILISEARCH_HOST",
        "NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY",
        "NEXT_PUBLIC_GA4_ID",
        "NEXT_PUBLIC_CLARITY_ID",
        "NEXT_PUBLIC_POSTHOG_KEY",
        "NEXT_PUBLIC_POSTHOG_HOST",
        "STORAGE_ENDPOINT",
        "STORAGE_ACCESS_KEY",
        "STORAGE_SECRET_KEY",
        "STORAGE_BUCKET",
        "STORAGE_REGION",
        "STORAGE_PUBLIC_URL",
        "NEXT_PUBLIC_STORAGE_PUBLIC_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    }
  }
}
